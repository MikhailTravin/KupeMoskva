<!DOCTYPE html>
<html lang="ru">

<head>
    <title>Спасибо</title>
    {% include 'blocks/head.njk' %}
</head>

<body class="preload mp">
    <div class="main-wrapper-outer">
        {% include 'blocks/header.njk' %}
        <main class="main">

            <div class="block-thanks">
                <img src="img/bg1.webp" alt="" class="block-thanks__bg">
                <div class="container">
                    <div class="block-thanks__content">
                        <img src="img/image12.webp" alt="" class="block-thanks__pic1">
                        <img src="img/image11.webp" alt="" class="block-thanks__pic2">
                        <div class="block-thanks__body">
                            <div class="block-thanks__icon">
                                <svg aria-hidden="true" width="70" height="62">
                                    <use xlink:href="img/sprite.svg#check1"></use>
                                </svg>
                            </div>
                            <div class="block-thanks__text">
                                <div class="block-thanks__title">
                                    Спасибо!
                                </div>
                                <p>
                                    Расчет отправлен на указаный номер
                                </p>
                            </div>
                            <div class="block-thanks__buttons">
                                <a href="https://kupemoskva.ru/shkafkupe_promo/" class="btn btn-green">
                                    <span>Наши работы</span>
                                </a>
                                <a href="./" data-popup="#call-surveyor" class="btn btn-yellow">
                                    <span>Вызвать замерщика</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="block-forms">
                <div class="container">
                    <div class="block-forms__content">
                        <h2 class="title3">
                            Остались вопросы <span>?</span>
                        </h2>
                        <form data-popup-message="#thanks" method="POST" action="sendmail.php" data-ajax class="form">
                            <div class="form__inputs">
                                <div class="form__input">
                                    <input data-required autocomplete="off" type="text" name="name"
                                        placeholder="Ваше имя" class="input">
                                    <div class="form__icon">
                                        <svg aria-hidden="true" width="11" height="12">
                                            <use xlink:href="img/sprite.svg#user"></use>
                                        </svg>
                                    </div>
                                </div>
                                <div class="form__input">
                                    <input data-required autocomplete="off" type="text" name="phone"
                                        placeholder="Номер телефона" class="input telephone">
                                    <div class="form__icon">
                                        <svg aria-hidden="true" width="12" height="12">
                                            <use xlink:href="img/sprite.svg#phone"></use>
                                        </svg>
                                    </div>
                                </div>
                            </div>
                            <div class="form__buttons">
                                <button type="submit" class="btn">Задать вопрос</button>
                                <div class="form__text">
                                    Нажимая на кнопку “Задать вопрос” вы соглашаетесь с <a href="./">политикой
                                        конфиденциальности</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

        </main>
        {% include 'blocks/footer.njk' %}
    </div>
    {% include 'blocks/popups.njk' %}
    {% include 'blocks/scripts.njk' %}
</body>

</html>